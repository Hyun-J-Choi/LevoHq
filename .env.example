# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Claude (Anthropic)
ANTHROPIC_API_KEY=

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Optional: local webhook testing if signed URL mismatches
# TWILIO_SKIP_SIGNATURE_VALIDATION=true

# Optional: if set, POST /api/twilio/send requires header x-twilio-send-secret
# (Browser UI “Send” buttons in this app do not send this header — leave unset
#  for in-app sends, or add a server-only route later.)
# TWILIO_SEND_SECRET=

# Vercel Cron (/api/cron/reminders) — Vercel sends Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Optional: absolute site URL for cron → POST /api/twilio/send (defaults to https://VERCEL_URL on Vercel)
# CRON_INTERNAL_BASE_URL=https://your-domain.com
# NEXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Business review link (post-visit cron)
# GOOGLE_BUSINESS_REVIEW_URL=https://g.page/r/your-place/review
